{
  "name": "erp-effect-http-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
