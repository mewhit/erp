{
	auto_https off
}

:8080 {
	encode zstd gzip

	handle /health-check {
		header Content-Type application/json
		respond "{\"status\":\"ok\"}" 200
	}

	@admin host erp-admin.mewhit.com
	handle @admin {
		root * /srv/admin
		try_files {path} /index.html
		file_server
	}

	@portal host erp.mewhit.com
	handle @portal {
		root * /srv/portal
		try_files {path} /index.html
		file_server
	}

	@api host erp-api.mewhit.com
	handle @api {
		reverse_proxy 127.0.0.1:3000
	}

	handle {
		respond "Unknown host" 404
	}
}
